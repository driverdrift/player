root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 4

[*.sh]
indent_style = tab
indent_size = 4
tab_width = 4

[*.py]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[{Makefile,*.mk}]
indent_style = tab
indent_size = 4
tab_width = 4

[*.php]
indent_style = space
indent_size = 4

[*.{html,js,css,json}]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2

[*.cmd]
indent_style = space
indent_size = 4
end_of_line = crlf

[*.ps1]
indent_style = space
indent_size = 4
end_of_line = lf
